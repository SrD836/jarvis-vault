# Syncthing version history (322 MB, do not commit — local backup only)
.stversions/
.stfolder/
.stignore

# Obsidian workspace state (changes every interaction, useless noise in diffs)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspaces.json
.obsidian/cache/
.obsidian/plugins/*/data.json

# Autogenerated indices and ephemeral state
.linker-index.json
LOOP_STATE.json

# Polymarket bot binaries — built per-host via docker, never sync
projects/polymarket-veto-loop-bot/bot/scanner/bin/
projects/polymarket-veto-loop-bot/bot/brain/bin/
projects/polymarket-veto-loop-bot/bot/executor/bin/
projects/polymarket-veto-loop-bot/bot/exit_monitor/bin/
inbox/.alerts.state
inbox/.alerts.log
inbox/.cron.log
**/.alerted

# Backup files (kept locally for rollback, not in history)
*.bak
*.bak-*
**/*.bak-*

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Trash
.trash/

# Temp / debug
*.tmp
.tmp/

# Awesome-CV upstream clone (public repo, no need to vendor)
cv-templates/awesome-cv-posquit0/
