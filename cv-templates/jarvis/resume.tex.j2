%!TEX TS-program = xelatex
%!TEX encoding = UTF-8 Unicode
% Generated by JARVIS cv_adapter_latex.py — DO NOT edit by hand

\documentclass[11pt, a4paper]{awesome-cv}

\geometry{left=1.4cm, top=.8cm, right=1.4cm, bottom=1.8cm, footskip=.5cm}

\colorlet{awesome}{awesome-{{ accent_color | default("nephritis") }}}
\setbool{acvSectionColorHighlight}{true}
\renewcommand{\acvHeaderSocialSep}{\quad\textbar\quad}

% PERSONAL
\name{ {{- first_name -}} }{ {{- last_name -}} }
\position{ {{- position -}} }
\address{ {{- address -}} }
\mobile{ {{- mobile -}} }
\email{ {{- email -}} }
{% if github %}\github{ {{- github -}} }{% endif %}
{% if linkedin %}\linkedin{ {{- linkedin -}} }{% endif %}
{% if homepage %}\homepage{ {{- homepage -}} }{% endif %}

{% if quote %}\quote{``{{ quote }}}{% endif %}

\begin{document}

\makecvheader[C]
\makecvfooter
  { \today }
  { {{ first_name }} {{ last_name }}~~~\textperiodcentered~~~Résumé }
  { \thepage }

% SUMMARY
{% if summary %}
\cvsection{ {{ summary_label | default("Summary") }} }
\begin{cvparagraph}
{{ summary }}
\end{cvparagraph}
{% endif %}

% EXPERIENCE
{% if experience %}
\cvsection{ {{ experience_label | default("Experience") }} }
\begin{cventries}
{% for x in experience %}
  \cventry
    { {{ x.role }} }
    { {{ x.company }} }
    { {{ x.location | default("") }} }
    { {{ x.dates }} }
    {
{% if x.bullets %}\begin{cvitems}
{% for b in x.bullets %}      \item { {{ b }} }
{% endfor %}    \end{cvitems}{% else %}{{ x.summary | default("") }}{% endif %}
    }
{% endfor %}
\end{cventries}
{% endif %}

% PROJECTS
{% if projects %}
\cvsection{ {{ projects_label | default("Projects") }} }
\begin{cventries}
{% for p in projects %}
  \cventry
    { {{ p.name }} }
    { {{ p.role | default("Creator") }} }
    { {{ p.stack | default("") }} }
    { {{ p.dates | default("") }} }
    {
\begin{cvitems}
      \item { {{ p.summary }} }
\end{cvitems}
    }
{% endfor %}
\end{cventries}
{% endif %}

% SKILLS
{% if skills_primary or skills_secondary %}
\cvsection{ {{ skills_label | default("Skills") }} }
\begin{cvskills}
{% if skills_primary %}  \cvskill { {{ skills_primary_label | default("Primary") }} }{ {{ skills_primary | join(", ") }} }{% endif %}
{% if skills_secondary %}  \cvskill { {{ skills_secondary_label | default("Also") }} }{ {{ skills_secondary | join(", ") }} }{% endif %}
{% if languages %}  \cvskill { {{ languages_label | default("Languages") }} }{ {% for l in languages %}{{ l.name }} ({{ l.level }}){% if not loop.last %}, {% endif %}{% endfor %} }{% endif %}
\end{cvskills}
{% endif %}

% CERTIFICATIONS
{% if certifications %}
\cvsection{ {{ certs_label | default("Certifications") }} }
\begin{cvhonors}
{% for c in certifications %}  \cvhonor { {{ c.title }} }{ }{ {{ c.issuer }} }{ {{ c.date | default("") }} }
{% endfor %}\end{cvhonors}
{% endif %}

% EDUCATION
{% if education %}
\cvsection{ {{ education_label | default("Education") }} }
\begin{cventries}
{% for e in education %}
  \cventry
    { {{ e.degree }} }
    { {{ e.institution }} }
    { {{ e.location | default("") }} }
    { {{ e.dates | default(e.year) | default("") }} }
    { {{ e.note | default("") }} }
{% endfor %}
\end{cventries}
{% endif %}

\end{document}
